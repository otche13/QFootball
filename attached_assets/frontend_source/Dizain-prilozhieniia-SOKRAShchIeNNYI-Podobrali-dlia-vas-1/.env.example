# Скопируй в .env и заполни
# cp .env.example .env

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/quality_football

# Telegram: username владельца магазина БЕЗ символа @
# Именно к нему будут перенаправляться покупатели при нажатии "Купить"
VITE_ADMIN_TG=your_telegram_username

# Сервер
PORT=5000
NODE_ENV=development
